---
/**
 * 顶部导航组件
 * 提供各页面入口，支持滚动后背景变化、非遗项目下拉菜单与移动端菜单
 */

/* 导航分组数据：非遗项目（下拉）+ 媒体展示 */
const craftItems = [
  { label: "陶瓷技艺", href: "/crafts/ceramic" },
  { label: "刺绣工艺", href: "/crafts/embroidery" },
  { label: "木雕技艺", href: "/crafts/woodcarving" }
];

const mediaItems = [
  { label: "首页", href: "/" },
  { label: "摄影", href: "/gallery" },
  { label: "视频", href: "/video" },
  { label: "3D", href: "/model" },
  { label: "游戏", href: "/game" }
];

const currentPath = Astro.url.pathname;

/* 判断当前路径是否属于非遗项目页 */
const isCraftsPage = currentPath.startsWith("/crafts");
---

<nav class="navigation" id="main-nav" aria-label="主导航">
  <div class="container nav-inner">
    <!-- 站点 Logo，点击返回首页 -->
    <a href="/" class="nav-logo" aria-label="返回首页">
      <span class="logo-text">非遗</span>
    </a>

    <!-- 桌面端导航链接 -->
    <ul class="nav-links" role="menubar">
      {/* 非遗项目下拉菜单 */}
      <li class="nav-item nav-dropdown" role="none">
        <button
          class="nav-link nav-dropdown-toggle"
          type="button"
          aria-expanded="false"
          aria-haspopup="true"
          aria-current={isCraftsPage ? "page" : undefined}
        >
          非遗项目 <span class="dropdown-arrow" aria-hidden="true">▾</span>
        </button>
        <ul class="dropdown-menu" role="menu">
          {craftItems.map(item => {
            const isActive = currentPath === item.href;
            return (
              <li role="none">
                <a
                  href={item.href}
                  class={`dropdown-link ${isActive ? "active" : ""}`}
                  role="menuitem"
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </li>

      {/* 媒体展示页链接 */}
      {mediaItems.map(item => {
        const isActive = currentPath === item.href;
        return (
          <li class="nav-item" role="none">
            <a
              href={item.href}
              class={`nav-link ${isActive ? "active" : ""}`}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- 移动端汉堡菜单按钮 -->
    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-label="打开导航菜单"
      aria-expanded="false"
      aria-controls="nav-menu"
      type="button"
    >
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
    </button>
  </div>
</nav>

<style>
  /* 导航栏基础样式 */
  .navigation {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--nav-height);
    z-index: 1000;
    transition: background-color 0.35s ease, box-shadow 0.35s ease;
    background-color: transparent;
  }

  /* 滚动后添加的样式，由 JS 控制 class */
  .navigation.scrolled {
    background-color: rgba(26, 26, 46, 0.95);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  .navigation.scrolled .nav-logo .logo-text {
    color: var(--color-text-light);
  }

  .navigation.scrolled .nav-link,
  .navigation.scrolled .nav-dropdown-toggle {
    color: var(--color-text-light);
  }

  .navigation.scrolled .nav-toggle .toggle-bar {
    background-color: var(--color-text-light);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo 样式 */
  .nav-logo {
    display: flex;
    align-items: center;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-text-light);
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.5);
    transition: color 0.35s ease;
  }

  /* 导航链接 */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .nav-link,
  .nav-dropdown-toggle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-light);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
    padding: var(--spacing-sm) 0;
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-link::after,
  .nav-dropdown-toggle::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-link:hover,
  .nav-link.active,
  .nav-dropdown-toggle:hover,
  .nav-dropdown-toggle[aria-current="page"] {
    color: var(--color-secondary);
  }

  .nav-link:hover::after,
  .nav-link.active::after,
  .nav-dropdown-toggle:hover::after,
  .nav-dropdown-toggle[aria-current="page"]::after {
    width: 100%;
  }

  /* 下拉菜单 */
  .nav-dropdown {
    position: relative;
  }

  .dropdown-arrow {
    font-size: 0.75rem;
    margin-left: 4px;
    transition: transform 0.3s ease;
  }

  .nav-dropdown-toggle[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    min-width: 160px;
    background-color: rgba(26, 26, 46, 0.98);
    border: 1px solid rgba(196, 163, 90, 0.3);
    border-radius: var(--radius-md);
    padding: var(--spacing-sm) 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-size: 0.9375rem;
    color: var(--color-text-light);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background-color: rgba(196, 163, 90, 0.15);
    color: var(--color-secondary);
  }

  /* 移动端菜单按钮 */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    padding: 4px;
  }

  .toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-light);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* 移动端响应式 */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      width: 100%;
      max-height: calc(100vh - var(--nav-height));
      overflow-y: auto;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: var(--spacing-md) var(--spacing-lg);
      background-color: rgba(26, 26, 46, 0.98);
      transform: translateY(-120%);
      opacity: 0;
      transition: transform 0.35s ease, opacity 0.35s ease;
      pointer-events: none;
    }

    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-item {
      width: 100%;
      border-bottom: 1px solid rgba(245, 240, 232, 0.1);
    }

    .nav-link,
    .nav-dropdown-toggle {
      display: block;
      width: 100%;
      padding: var(--spacing-md) 0;
      text-align: left;
    }

    .nav-link::after,
    .nav-dropdown-toggle::after {
      display: none;
    }

    /* 移动端下拉菜单展开为内联列表 */
    .dropdown-menu {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      background-color: transparent;
      border: none;
      box-shadow: none;
      padding: 0 0 var(--spacing-sm) var(--spacing-md);
      display: none;
    }

    .nav-dropdown.open .dropdown-menu {
      display: block;
    }

    .dropdown-link {
      padding: var(--spacing-sm) var(--spacing-md);
      font-size: 0.875rem;
    }
  }
</style>

<script>
  /**
   * 导航栏交互脚本
   * 1. 监听页面滚动，控制导航栏背景变化
   * 2. 控制移动端菜单展开/收起
   * 3. 控制移动端非遗项目下拉菜单展开/收起
   */
  document.addEventListener("DOMContentLoaded", () => {
    const nav = document.getElementById("main-nav");
    const toggle = document.getElementById("nav-toggle");
    const navLinks = nav?.querySelector(".nav-links") as HTMLElement | null;
    const dropdownToggle = nav?.querySelector(".nav-dropdown-toggle") as HTMLElement | null;
    const dropdown = nav?.querySelector(".nav-dropdown") as HTMLElement | null;

    if (!nav) return;

    // 滚动监听：超过导航栏高度后添加 scrolled 类
    const handleScroll = () => {
      if (window.scrollY > nav.offsetHeight) {
        nav.classList.add("scrolled");
      } else {
        nav.classList.remove("scrolled");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    // 移动端菜单切换
    if (toggle && navLinks) {
      toggle.addEventListener("click", () => {
        const isOpen = navLinks.classList.toggle("open");
        toggle.setAttribute("aria-expanded", String(isOpen));
      });

      // 点击导航链接后自动关闭菜单
      navLinks.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          navLinks.classList.remove("open");
          toggle.setAttribute("aria-expanded", "false");
          // 同时关闭下拉菜单
          if (dropdown) dropdown.classList.remove("open");
        });
      });
    }

    // 移动端非遗项目下拉菜单切换
    if (dropdownToggle && dropdown) {
      dropdownToggle.addEventListener("click", (e) => {
        // 仅在移动端响应点击展开（桌面端用 hover）
        if (window.innerWidth <= 768) {
          e.preventDefault();
          const isOpen = dropdown.classList.toggle("open");
          dropdownToggle.setAttribute("aria-expanded", String(isOpen));
        }
      });
    }
  });
</script>
