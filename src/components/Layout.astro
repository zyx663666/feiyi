---
/**
 * 全局布局组件
 * 所有页面共享的 HTML 骨架、字体加载、导航栏和页脚
 */
import ThemeToggle from "./ThemeToggle.astro";
import MusicPlayer from "./MusicPlayer.astro";

interface Props {
  /** 页面标题，将拼接在站点名后 */
  title?: string;
  /** 页面描述，用于 SEO */
  description?: string;
}

const { title, description = "非遗传承 - 数字媒体应用课程设计" } = Astro.props;
const siteName = "非遗传承";
const pageTitle = title ? `${title} | ${siteName}` : siteName;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>

  <!-- Google Fonts：思源宋体、思源黑体、马善政书法体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Sans+SC:wght@300;400;700&family=Noto+Serif+SC:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <!-- 全局样式 -->
  <link rel="stylesheet" href="/src/styles/global.css" />

  <!-- 防闪烁：立即应用保存的主题色 -->
  <script is:inline>
    (function () {
      try {
        var hue = localStorage.getItem("feiyi-theme-hue");
        if (hue) {
          document.documentElement.style.setProperty("--hue", hue);
        }
        var mode = localStorage.getItem("feiyi-theme-mode");
        if (mode === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <slot />

  <!-- 主题色切换器（右上角） -->
  <ThemeToggle />

  <!-- 音乐播放器（右下角） -->
  <MusicPlayer />
</body>
</html>
