---
/**
 * 摄影展示页
 * 瀑布流画廊 + 分类筛选 + 灯箱查看
 * 使用 CSS 渐变占位图，后续可替换为真实摄影作品
 */
import Layout from "../components/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

/**
 * 摄影作品数据
 * src: 图片路径
 * category: 分类（ceramic/embroidery/woodcarving/heritage）
 * ratio: 图片宽高比（用于瀑布流高度）
 */
const photos = [
  // 陶瓷
  { id: 1, title: "青花缠枝", desc: "元青花瓷瓶纹饰特写", category: "ceramic", ratio: "3/4", src: Astro.resolve("/images/gallery/ceramic/陶瓷1.jpg") },
  { id: 2, title: "窑火千年", desc: "龙窑柴烧现场记录", category: "ceramic", ratio: "4/3", src: Astro.resolve("/images/gallery/ceramic/陶瓷2.jpg") },
  { id: 3, title: "釉色天成", desc: "汝窑天青釉碗", category: "ceramic", ratio: "1/1", src: Astro.resolve("/images/gallery/ceramic/陶瓷3.jpg") },
  { id: 4, title: "拉坯成形", desc: "匠人拉坯瞬间", category: "ceramic", ratio: "3/4", src: Astro.resolve("/images/gallery/ceramic/陶瓷4.jpg") },
  { id: 5, title: "紫砂韵味", desc: "宜兴紫砂壶细节", category: "ceramic", ratio: "4/5", src: Astro.resolve("/images/gallery/ceramic/陶瓷5.jpg") },
  { id: 6, title: "瓷韵流光", desc: "瓷器釉面光泽特写", category: "ceramic", ratio: "3/4", src: Astro.resolve("/images/gallery/ceramic/陶瓷6.jpg") },
  { id: 7, title: "匠心独运", desc: "陶瓷制作工艺", category: "ceramic", ratio: "4/3", src: Astro.resolve("/images/gallery/ceramic/陶瓷7.jpg") },

  // 刺绣
  { id: 8, title: "丝线千缕", desc: "苏绣双面绣工艺", category: "embroidery", ratio: "3/4", src: Astro.resolve("/images/gallery/embroidery/刺绣1.jpg") },
  { id: 9, title: "针走游龙", desc: "蜀绣龙纹绣片", category: "embroidery", ratio: "4/3", src: Astro.resolve("/images/gallery/embroidery/刺绣2.jpg") },
  { id: 10, title: "锦绣山河", desc: "湘绣山水绣品", category: "embroidery", ratio: "1/1", src: Astro.resolve("/images/gallery/embroidery/刺绣3.png") },

  // 木雕
  { id: 12, title: "刀木春秋", desc: "东阳木雕屏风", category: "woodcarving", ratio: "4/5", src: Astro.resolve("/images/gallery/woodcarving/wood1.jpg") },
  { id: 13, title: "雕梁画栋", desc: "徽派建筑木雕", category: "woodcarving", ratio: "3/4", src: Astro.resolve("/images/gallery/woodcarving/wood2.jpg") },
  { id: 14, title: "精雕细琢", desc: "黄杨木雕人物", category: "woodcarving", ratio: "1/1", src: Astro.resolve("/images/gallery/woodcarving/wood3.jpg") },
  { id: 15, title: "木屑飞舞", desc: "匠人雕刻现场", category: "woodcarving", ratio: "4/3", src: Astro.resolve("/images/gallery/woodcarving/wood4.jpg") },

  // 传承人
  { id: 16, title: "匠心独运", desc: "陶瓷传承人肖像", category: "heritage", ratio: "3/4", src: Astro.resolve("/images/gallery/heritage/1.jpg") },
  { id: 17, title: "岁月留痕", desc: "老匠人的双手", category: "heritage", ratio: "4/3", src: Astro.resolve("/images/gallery/heritage/2.jpg") },
  { id: 18, title: "薪火相传", desc: "章细莲老师", category: "heritage", ratio: "1/1", src: Astro.resolve("/images/gallery/heritage/章细莲.jpg") },
  { id: 19, title: "守艺人", desc: "陈新华老师", category: "heritage", ratio: "3/4", src: Astro.resolve("/images/gallery/heritage/陈新华.png") },
];

const categories = [
  { id: "all", label: "全部" },
  { id: "ceramic", label: "陶瓷" },
  { id: "embroidery", label: "刺绣" },
  { id: "woodcarving", label: "木雕" },
  { id: "heritage", label: "传承人" },
];
---

<Layout title="光影非遗 - 摄影展示">
  <Navigation />

  <main class="gallery-main">
    <!-- Hero 区域 -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="hero-subtitle reveal" data-delay="0">PHOTOGRAPHY</p>
        <h1 class="hero-title reveal" data-delay="200">光影非遗</h1>
        <p class="hero-desc reveal" data-delay="400">用镜头记录传统技艺之美</p>
        <div class="hero-line reveal" data-delay="600"></div>
      </div>
      <div class="hero-scroll reveal" data-delay="800">
        <span>向下探索</span>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- 分类筛选 -->
    <section class="filter-section" id="filter-section">
      <div class="container">
        <div class="filter-bar">
          {categories.map((cat, i) => (
            <button
              class={`filter-btn ${i === 0 ? "active" : ""}`}
              data-category={cat.id}
              data-delay={i * 80}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- 瀑布流画廊 -->
    <section class="gallery-section">
      <div class="container">
        <div class="masonry" id="masonry">
          {photos.map((photo, i) => (
            <div
              class="photo-card"
              data-category={photo.category}
              data-id={photo.id}
              data-delay={(i % 4) * 100 + Math.floor(i / 4) * 60}
            >
              <div
                class="photo-img"
                style={`background-image: url('${photo.src}'); aspect-ratio: ${photo.ratio};`}
              >
                <div class="photo-overlay">
                  <h3 class="photo-title">{photo.title}</h3>
                  <p class="photo-desc">{photo.desc}</p>
                  <span class="photo-zoom">点击查看</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- 灯箱 -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="关闭">×</button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="上一张">‹</button>
    <button class="lightbox-next" id="lightbox-next" aria-label="下一张">›</button>
    <div class="lightbox-content">
      <div class="lightbox-img" id="lightbox-img"></div>
      <div class="lightbox-info">
        <h3 class="lightbox-title" id="lightbox-title"></h3>
        <p class="lightbox-desc" id="lightbox-desc"></p>
        <p class="lightbox-meta" id="lightbox-meta"></p>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  /* ============================================
   * 主容器
   * ============================================ */
  .gallery-main {
    padding-top: var(--nav-height);
  }

  /* ============================================
   * Hero 区域
   * ============================================ */
  .hero {
    position: relative;
    height: 85vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 30%, #2d1f3a 70%, #1a1a2e 100%);
    z-index: 1;
  }

  /* Hero 背景动态光晕 */
  .hero-bg::before {
    content: "";
    position: absolute;
    top: 20%;
    left: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(196, 163, 90, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    animation: floatGlow 8s ease-in-out infinite;
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    bottom: 10%;
    right: 15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(178, 34, 34, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    animation: floatGlow 10s ease-in-out infinite reverse;
  }

  @keyframes floatGlow {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(40px, -30px) scale(1.1); opacity: 1; }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(15, 15, 26, 0.4) 100%);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    color: var(--color-text-light);
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.5em;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-lg);
    opacity: 0.8;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 400;
    color: var(--color-text-light);
    text-shadow: 0 4px 30px rgba(196, 163, 90, 0.3);
    margin-bottom: var(--spacing-md);
    letter-spacing: 0.1em;
  }

  .hero-desc {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: rgba(245, 240, 232, 0.8);
    margin-bottom: var(--spacing-lg);
    letter-spacing: 0.2em;
  }

  .hero-line {
    width: 60px;
    height: 2px;
    margin: 0 auto;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
    animation: lineExpand 2s ease-in-out infinite;
  }

  @keyframes lineExpand {
    0%, 100% { width: 60px; opacity: 0.6; }
    50% { width: 120px; opacity: 1; }
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: rgba(245, 240, 232, 0.6);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-align: center;
  }

  .scroll-arrow {
    width: 1px;
    height: 40px;
    margin: 12px auto 0;
    background: linear-gradient(to bottom, var(--color-secondary), transparent);
    position: relative;
    animation: scrollDown 2s ease-in-out infinite;
  }

  .scroll-arrow::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 8px;
    height: 8px;
    border-right: 1px solid var(--color-secondary);
    border-bottom: 1px solid var(--color-secondary);
  }

  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ============================================
   * 分类筛选栏
   * ============================================ */
  .filter-section {
    position: sticky;
    top: var(--nav-height);
    z-index: 50;
    background: rgba(26, 26, 46, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(196, 163, 90, 0.15);
    padding: var(--spacing-md) 0;
  }

  .filter-bar {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: rgba(245, 240, 232, 0.6);
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-pill);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .filter-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .filter-btn:hover {
    color: var(--color-text-light);
  }

  .filter-btn.active {
    color: var(--color-text-light);
    box-shadow: 0 0 20px rgba(196, 163, 90, 0.3);
  }

  .filter-btn.active::before {
    opacity: 1;
  }

  /* ============================================
   * 瀑布流画廊
   * ============================================ */
  .gallery-section {
    background: var(--color-bg-dark);
    padding: var(--spacing-2xl) 0;
    min-height: 50vh;
  }

  .masonry {
    column-count: 4;
    column-gap: var(--spacing-md);
  }

  @media (max-width: 1200px) {
    .masonry { column-count: 3; }
  }

  @media (max-width: 768px) {
    .masonry { column-count: 2; column-gap: var(--spacing-sm); }
  }

  @media (max-width: 480px) {
    .masonry { column-count: 1; }
  }

  .photo-card {
    break-inside: avoid;
    margin-bottom: var(--spacing-md);
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    position: relative;
    background: var(--color-bg-medium);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.4s ease;
  }

  .photo-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4),
                0 0 0 1px rgba(196, 163, 90, 0.3);
  }

  .photo-img {
    width: 100%;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--color-bg-medium);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--spacing-lg);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .photo-card:hover .photo-overlay {
    opacity: 1;
  }

  .photo-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-xs);
    transform: translateY(10px);
    transition: transform 0.4s ease 0.1s;
  }

  .photo-card:hover .photo-title {
    transform: translateY(0);
  }

  .photo-desc {
    font-size: 0.875rem;
    color: rgba(245, 240, 232, 0.8);
    margin-bottom: var(--spacing-sm);
    transform: translateY(10px);
    transition: transform 0.4s ease 0.2s;
  }

  .photo-card:hover .photo-desc {
    transform: translateY(0);
  }

  .photo-zoom {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--color-secondary);
    letter-spacing: 0.2em;
    border-top: 1px solid rgba(196, 163, 90, 0.3);
    padding-top: var(--spacing-sm);
    transform: translateY(10px);
    opacity: 0;
    transition: all 0.4s ease 0.3s;
  }

  .photo-card:hover .photo-zoom {
    transform: translateY(0);
    opacity: 1;
  }

  /* ============================================
   * 灯箱
   * ============================================ */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-xl);
  }

  .lightbox.active {
    display: flex;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .lightbox-content {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
    animation: zoomIn 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @keyframes zoomIn {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .lightbox-img {
    width: 100%;
    max-height: 70vh;
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
  }

  .lightbox-info {
    text-align: center;
    color: var(--color-text-light);
  }

  .lightbox-title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-xs);
  }

  .lightbox-desc {
    font-size: 1rem;
    color: rgba(245, 240, 232, 0.7);
    margin-bottom: var(--spacing-xs);
  }

  .lightbox-meta {
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.4);
    letter-spacing: 0.2em;
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    color: var(--color-text-light);
    font-size: 2.5rem;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.3s ease;
    background: rgba(255, 255, 255, 0.05);
  }

  .lightbox-close {
    top: var(--spacing-lg);
    right: var(--spacing-lg);
  }

  .lightbox-prev {
    left: var(--spacing-lg);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: var(--spacing-lg);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(196, 163, 90, 0.2);
    color: var(--color-secondary);
  }

  /* ============================================
   * 缓入动画
   * ============================================ */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-card {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .photo-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .photo-card.hidden {
    display: none;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .hero { height: 70vh; min-height: 500px; }
    .lightbox { padding: var(--spacing-md); }
    .lightbox-close, .lightbox-prev, .lightbox-next {
      width: 44px; height: 44px; font-size: 2rem;
    }
    .lightbox-prev { left: var(--spacing-sm); }
    .lightbox-next { right: var(--spacing-sm); }
  }
</style>

<script>
  /**
   * 摄影页面交互脚本
   * 1. 元素缓入动画（IntersectionObserver）
   * 2. 分类筛选功能
   * 3. 灯箱查看与切换
   */
  document.addEventListener("DOMContentLoaded", () => {
    // ===== 1. 元素缓入动画 =====
    const revealElements = document.querySelectorAll(".reveal");
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.dataset.delay || "0");
            setTimeout(() => entry.target.classList.add("visible"), delay);
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    revealElements.forEach((el) => revealObserver.observe(el));

    // 图片卡片缓入
    const photoCards = document.querySelectorAll(".photo-card");
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.dataset.delay || "0");
            setTimeout(() => entry.target.classList.add("visible"), delay);
            cardObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    photoCards.forEach((card) => cardObserver.observe(card));

    // ===== 2. 分类筛选 =====
    const filterBtns = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".photo-card");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        // 更新按钮状态
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        const category = btn.getAttribute("data-category");

        // 筛选卡片
        cards.forEach((card) => {
          const cardCategory = card.getAttribute("data-category");
          if (category === "all" || cardCategory === category) {
            card.classList.remove("hidden");
            // 重新触发动画
            card.classList.remove("visible");
            void card.offsetWidth; // 强制重排
            card.classList.add("visible");
          } else {
            card.classList.add("hidden");
          }
        });
      });
    });

    // ===== 3. 灯箱功能 =====
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLElement;
    const lightboxTitle = document.getElementById("lightbox-title") as HTMLElement;
    const lightboxDesc = document.getElementById("lightbox-desc") as HTMLElement;
    const lightboxMeta = document.getElementById("lightbox-meta") as HTMLElement;
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");

    // 获取当前可见的图片列表
    const getVisibleCards = () =>
      Array.from(document.querySelectorAll<HTMLElement>(".photo-card:not(.hidden)"));

    let currentIndex = 0;

    const openLightbox = (card: HTMLElement) => {
      const cards = getVisibleCards();
      currentIndex = cards.indexOf(card);
      updateLightbox();
      lightbox?.classList.add("active");
      document.body.style.overflow = "hidden";
    };

    const updateLightbox = () => {
      const cards = getVisibleCards();
      const card = cards[currentIndex];
      if (!card) return;

      const img = card.querySelector(".photo-img") as HTMLElement;
      const title = card.querySelector(".photo-title") as HTMLElement;
      const desc = card.querySelector(".photo-desc") as HTMLElement;

      // 复制背景图片样式
      lightboxImg.style.cssText = img.style.cssText;
      lightboxImg.style.width = "100%";
      lightboxImg.style.maxHeight = "70vh";

      lightboxTitle.textContent = title.textContent || "";
      lightboxDesc.textContent = desc.textContent || "";

      const category = card.getAttribute("data-category");
      const categoryMap: Record<string, string> = {
        ceramic: "陶瓷",
        embroidery: "刺绣",
        woodcarving: "木雕",
        heritage: "传承人",
      };
      lightboxMeta.textContent = `分类：${categoryMap[category] || ""} · ${currentIndex + 1} / ${cards.length}`;
    };

    const closeLightbox = () => {
      lightbox?.classList.remove("active");
      document.body.style.overflow = "";
    };

    const showPrev = () => {
      const cards = getVisibleCards();
      currentIndex = (currentIndex - 1 + cards.length) % cards.length;
      updateLightbox();
    };

    const showNext = () => {
      const cards = getVisibleCards();
      currentIndex = (currentIndex + 1) % cards.length;
      updateLightbox();
    };

    // 绑定事件
    photoCards.forEach((card) => {
      card.addEventListener("click", () => openLightbox(card as HTMLElement));
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", showPrev);
    lightboxNext?.addEventListener("click", showNext);

    // 点击背景关闭
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // 键盘控制
    document.addEventListener("keydown", (e) => {
      if (!lightbox?.classList.contains("active")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") showPrev();
      if (e.key === "ArrowRight") showNext();
    });

    // ===== 4. Hero 视差效果 =====
    const heroBg = document.querySelector(".hero-bg") as HTMLElement;
    window.addEventListener("scroll", () => {
      const scrolled = window.scrollY;
      if (scrolled < window.innerHeight) {
        heroBg.style.transform = `translateY(${scrolled * 0.4}px)`;
      }
    }, { passive: true });
  });
</script>
