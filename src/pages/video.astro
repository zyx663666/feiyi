<script>
  /**
   * 视频页交互逻辑
   * 三大模块：
   *   1. 背景图水波纹涟漪效果（canvas绘制扩散圆环）
   *   2. 顶部轮播图：自动循环播放视频片段，支持手动切换与静音控制
   *   3. 自定义播放器：播放/暂停/进度/音量/全屏 + B站风格选集切换
   */
  document.addEventListener("DOMContentLoaded", () => {
    /* ====================================================
     * 一、背景图区域水波纹涟漪
     * 原理：鼠标在 banner 上移动时，记录点位生成扩散圆环
     *       每个圆环半径递增、透明度递减，形成水波涟漪
     * ==================================================== */
    const rippleBanners = document.querySelectorAll<HTMLElement>("[data-ripple]");

    rippleBanners.forEach((banner) => {
      const canvas = banner.querySelector<HTMLCanvasElement>(".ripple-canvas");
      if (!canvas) return;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      // 涟漪对象数组
      const ripples: Array<{
        x: number;
        y: number;
        radius: number;
        maxRadius: number;
        opacity: number;
        color: string;
      }> = [];

      // 调整 canvas 尺寸匹配容器
      function resizeCanvas() {
        const rect = banner.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      }
      resizeCanvas();
      window.addEventListener("resize", resizeCanvas);

      // 鼠标移动时生成涟漪（节流：每 80ms 最多生成一个）
      let lastRippleTime = 0;
      banner.addEventListener("mousemove", (e) => {
        const now = Date.now();
        if (now - lastRippleTime < 80) return;
        lastRippleTime = now;

        const rect = banner.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ripples.push({
          x,
          y,
          radius: 0,
          maxRadius: 120 + Math.random() * 60,
          opacity: 0.6,
          color: "rgba(245, 240, 232, 0.8)",
        });

        // 限制涟漪数量，避免性能问题
        if (ripples.length > 15) ripples.shift();
      });

      // 点击时生成更强的涟漪
      banner.addEventListener("click", (e) => {
        const rect = banner.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        ripples.push({
          x,
          y,
          radius: 0,
          maxRadius: 200,
          opacity: 0.9,
          color: "rgba(245, 240, 232, 1)",
        });
      });

      // 动画循环：绘制并更新所有涟漪
      function animateRipples() {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let i = ripples.length - 1; i >= 0; i--) {
          const r = ripples[i];
          r.radius += 2.5;
          r.opacity -= 0.012;

          if (r.opacity <= 0 || r.radius >= r.maxRadius) {
            ripples.splice(i, 1);
            continue;
          }

          // 绘制涟漪圆环
          ctx.beginPath();
          ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
          ctx.strokeStyle = r.color.replace(/[\d.]+\)$/g, `${r.opacity})`);
          ctx.lineWidth = 2;
          ctx.stroke();

          // 内圈淡色填充，增强水波感
          ctx.beginPath();
          ctx.arc(r.x, r.y, r.radius * 0.6, 0, Math.PI * 2);
          ctx.strokeStyle = r.color.replace(/[\d.]+\)$/g, `${r.opacity * 0.4})`);
          ctx.lineWidth = 1;
          ctx.stroke();
        }

        requestAnimationFrame(animateRipples);
      }
      animateRipples();
    });

    /* ====================================================
     * 二、顶部视频轮播图
     * 功能：自动循环播放5个视频的片段，每个播放CLIP_DURATION秒后切换
     *       支持手动点击切换、静音/取消静音
     * 注意：自动播放需muted（浏览器策略要求）
     * ==================================================== */
    const carousel = document.querySelector<HTMLElement>("[data-carousel]");
    if (carousel) {
      const carouselVideo = carousel.querySelector<HTMLVideoElement>("[data-carousel-video]");
      const carouselItems = carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-item]");
      const titleEl = carousel.querySelector<HTMLElement>("[data-carousel-title]");
      const subtitleEl = carousel.querySelector<HTMLElement>("[data-carousel-subtitle]");
      const categoryEl = carousel.querySelector<HTMLElement>("[data-carousel-category]");
      const progressBar = carousel.querySelector<HTMLElement>("[data-carousel-progress-bar]");
      const muteBtn = carousel.querySelector<HTMLButtonElement>("[data-carousel-mute]");
      const iconMuted = muteBtn?.querySelector<HTMLElement>(".icon-muted");
      const iconSound = muteBtn?.querySelector<HTMLElement>(".icon-sound");

      // 每个视频片段的播放时长（秒），到时自动切换
      const CLIP_DURATION = 15;

      let currentIndex = 0;
      // 进度定时器引用，切换时需清除
      let progressTimer: number | null = null;
      // 视频是否就绪标记，防止canplay重复触发计时器
      let isVideoReady = false;

      /**
       * 切换到指定索引的视频
       * 仅设置视频源与UI状态，不立即启动计时器
       * 计时器在视频canplay事件（可播放）后启动，确保大文件也能完整播放CLIP_DURATION秒
       * @param index 视频在轮播列表中的索引
       */
      function switchVideo(index: number) {
        if (!carouselVideo) return;
        const item = carouselItems[index];
        if (!item) return;

        currentIndex = index;
        // 重置就绪标记，等待新视频canplay
        isVideoReady = false;

        // 清除上一个视频的计时器
        if (progressTimer !== null) {
          window.clearInterval(progressTimer);
          progressTimer = null;
        }

        // 更新视频源
        const src = item.dataset.videoSrc || "";
        carouselVideo.src = src;
        // 静音自动播放（浏览器策略要求muted才能自动播放）
        carouselVideo.play().catch(() => {
          // 自动播放失败时忽略（用户未交互时浏览器可能阻止）
        });

        // 更新标题信息
        if (titleEl) titleEl.textContent = item.dataset.videoTitle || "";
        if (subtitleEl) subtitleEl.textContent = item.dataset.videoSubtitle || "";
        if (categoryEl) categoryEl.textContent = item.dataset.videoCategory || "";

        // 更新列表项高亮状态
        carouselItems.forEach((el, i) => {
          el.classList.toggle("active", i === index);
        });

        // 重置进度条
        if (progressBar) progressBar.style.width = "0%";
      }

      /**
       * 启动进度条定时器
       * 每100ms更新一次进度条宽度，达到CLIP_DURATION后切换到下一个视频
       * 仅在视频canplay后调用，确保视频能完整播放CLIP_DURATION秒
       */
      function startProgressTimer() {
        if (progressTimer !== null) {
          window.clearInterval(progressTimer);
        }
        let elapsed = 0;
        progressTimer = window.setInterval(() => {
          elapsed += 0.1;
          const percent = Math.min((elapsed / CLIP_DURATION) * 100, 100);
          if (progressBar) progressBar.style.width = `${percent}%`;

          // 达到切片时长，切换到下一个视频（循环）
          if (elapsed >= CLIP_DURATION) {
            const nextIndex = (currentIndex + 1) % carouselItems.length;
            switchVideo(nextIndex);
          }
        }, 100);
      }

      // 列表项点击：手动切换到指定视频
      carouselItems.forEach((item, index) => {
        item.addEventListener("click", () => {
          switchVideo(index);
        });
      });

      // 静音切换按钮
      muteBtn?.addEventListener("click", () => {
        if (!carouselVideo) return;
        carouselVideo.muted = !carouselVideo.muted;
        if (iconMuted && iconSound) {
          iconMuted.style.display = carouselVideo.muted ? "inline" : "none";
          iconSound.style.display = carouselVideo.muted ? "none" : "inline";
        }
      });

      /**
       * 视频可播放事件：视频加载足够数据后触发
       * 在此事件后启动15秒计时器，确保大文件也能完整播放CLIP_DURATION秒
       * 通过isVideoReady标记防止重复启动
       */
      carouselVideo?.addEventListener("canplay", () => {
        if (!isVideoReady) {
          isVideoReady = true;
          startProgressTimer();
        }
      });

      /**
       * 视频加载失败处理：自动切换到下一个视频，避免轮播卡死
       */
      carouselVideo?.addEventListener("error", () => {
        const nextIndex = (currentIndex + 1) % carouselItems.length;
        switchVideo(nextIndex);
      });

      // 初始化：加载第一个视频
      switchVideo(0);
    }

    /* ====================================================
     * 三、自定义视频播放器（三大专题通用）
     * 功能：播放/暂停、进度条拖拽、音量、全屏、选集切换
     * 每个专题独立初始化一个播放器实例
     * ==================================================== */
    const players = document.querySelectorAll<HTMLElement>("[data-craft-player]");

    players.forEach((player) => {
      const video = player.querySelector<HTMLVideoElement>("[data-player-video]");
      const bigPlayBtn = player.querySelector<HTMLButtonElement>("[data-player-big-play]");
      const playBtn = player.querySelector<HTMLButtonElement>("[data-player-play]");
      const muteToggleBtn = player.querySelector<HTMLButtonElement>("[data-player-mute]");
      const fullscreenBtn = player.querySelector<HTMLButtonElement>("[data-player-fullscreen]");
      const progress = player.querySelector<HTMLElement>("[data-player-progress]");
      const filled = player.querySelector<HTMLElement>("[data-player-filled]");
      const buffer = player.querySelector<HTMLElement>("[data-player-buffer]");
      const thumb = player.querySelector<HTMLElement>("[data-player-thumb]");
      const timeEl = player.querySelector<HTMLElement>("[data-player-time]");
      const volumeSlider = player.querySelector<HTMLInputElement>("[data-player-volume]");
      const loading = player.querySelector<HTMLElement>("[data-player-loading]");
      const playlistItems = player.querySelectorAll<HTMLButtonElement>("[data-playlist-item]");
      const accentColor = player.dataset.accent || "#c4a35a";

      // 设置进度条填充颜色为主题色
      if (filled) filled.style.background = accentColor;
      if (thumb) thumb.style.background = accentColor;

      if (!video) return;

      /**
       * 时间格式化：秒数转 mm:ss 格式
       * @param seconds 秒数
       * @returns 格式化后的时间字符串
       */
      function formatTime(seconds: number): string {
        if (isNaN(seconds) || !isFinite(seconds)) return "00:00";
        const m = Math.floor(seconds / 60);
        const s = Math.floor(seconds % 60);
        return `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
      }

      /**
       * 更新播放/暂停按钮图标显示
       */
      function updatePlayIcon() {
        if (!playBtn) return;
        const iconPlay = playBtn.querySelector<HTMLElement>(".icon-play");
        const iconPause = playBtn.querySelector<HTMLElement>(".icon-pause");
        if (iconPlay && iconPause) {
          iconPlay.style.display = video.paused ? "inline" : "none";
          iconPause.style.display = video.paused ? "none" : "inline";
        }
        // 大播放按钮在暂停态显示
        if (bigPlayBtn) {
          bigPlayBtn.style.display = video.paused ? "flex" : "none";
        }
      }

      /**
       * 切换播放/暂停状态
       * 若视频源未加载，先加载第一个选集视频并自动播放
       */
      function togglePlay() {
        // 视频源未加载时，先触发延迟加载
        if (!videoLoaded) {
          loadFirstVideo();
          return;
        }
        if (video.paused) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      }

      // 播放/暂停按钮点击
      playBtn?.addEventListener("click", togglePlay);
      bigPlayBtn?.addEventListener("click", togglePlay);

      // 视频点击切换播放/暂停
      video.addEventListener("click", togglePlay);

      // 播放状态变化时更新图标
      video.addEventListener("play", updatePlayIcon);
      video.addEventListener("pause", updatePlayIcon);

      // 加载中显示提示
      video.addEventListener("waiting", () => {
        loading?.classList.add("show");
      });
      video.addEventListener("playing", () => {
        loading?.classList.remove("show");
      });

      /**
       * 更新进度条位置
       * @param clientX 鼠标X坐标（用于点击/拖拽跳转）
       */
      function updateProgress(clientX: number) {
        if (!progress) return;
        const rect = progress.getBoundingClientRect();
        // 计算点击位置占比，限制在0~1之间
        let percent = (clientX - rect.left) / rect.width;
        percent = Math.max(0, Math.min(1, percent));
        // 更新进度条视觉
        if (filled) filled.style.width = `${percent * 100}%`;
        if (thumb) thumb.style.left = `${percent * 100}%`;
        // 跳转视频播放位置
        if (video.duration) {
          video.currentTime = percent * video.duration;
        }
      }

      // 进度条点击跳转
      progress?.addEventListener("click", (e) => {
        updateProgress(e.clientX);
      });

      // 进度条拖拽跳转
      let isDragging = false;
      progress?.addEventListener("mousedown", (e) => {
        isDragging = true;
        updateProgress(e.clientX);
      });
      document.addEventListener("mousemove", (e) => {
        if (isDragging) updateProgress(e.clientX);
      });
      document.addEventListener("mouseup", () => {
        isDragging = false;
      });

      // 视频时间更新：同步进度条与时间显示
      video.addEventListener("timeupdate", () => {
        if (!video.duration) return;
        const percent = (video.currentTime / video.duration) * 100;
        if (filled) filled.style.width = `${percent}%`;
        if (thumb) thumb.style.left = `${percent}%`;
        if (timeEl) {
          timeEl.textContent = `${formatTime(video.currentTime)} / ${formatTime(video.duration)}`;
        }
      });

      // 缓冲进度更新
      video.addEventListener("progress", () => {
        if (video.buffered.length > 0 && video.duration) {
          const bufferedEnd = video.buffered.end(video.buffered.length - 1);
          const percent = (bufferedEnd / video.duration) * 100;
          if (buffer) buffer.style.width = `${percent}%`;
        }
      });

      // 音量滑块控制
      volumeSlider?.addEventListener("input", (e) => {
        const target = e.target as HTMLInputElement;
        const vol = parseFloat(target.value);
        video.volume = vol;
        video.muted = vol === 0;
        updateMuteIcon();
      });

      /**
       * 更新静音按钮图标显示
       */
      function updateMuteIcon() {
        if (!muteToggleBtn) return;
        const iconSound = muteToggleBtn.querySelector<HTMLElement>(".icon-sound");
        const iconMuted = muteToggleBtn.querySelector<HTMLElement>(".icon-muted");
        if (iconSound && iconMuted) {
          iconSound.style.display = video.muted ? "none" : "inline";
          iconMuted.style.display = video.muted ? "inline" : "none";
        }
      }

      // 静音切换按钮
      muteToggleBtn?.addEventListener("click", () => {
        video.muted = !video.muted;
        if (volumeSlider) {
          volumeSlider.value = video.muted ? "0" : String(video.volume);
        }
        updateMuteIcon();
      });

      // 全屏切换
      fullscreenBtn?.addEventListener("click", () => {
        const stage = player.querySelector<HTMLElement>(".player-stage");
        if (!stage) return;
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          stage.requestFullscreen().catch(() => {});
        }
      });

      // 监听全屏变化，调整视频尺寸
      document.addEventListener("fullscreenchange", () => {
        if (document.fullscreenElement) {
          video.style.height = "100%";
          video.style.objectFit = "contain";
        } else {
          video.style.height = "";
          video.style.objectFit = "";
        }
      });

      /**
       * 切换播放器视频源（选集切换）
       * @param src 视频源地址
       * @param activeItem 当前选中的选集按钮元素
       */
      function switchPlaylistVideo(src: string, activeItem: HTMLButtonElement) {
        if (!src) return;
        // 标记视频已加载，防止延迟加载覆盖手动切换的视频源
        videoLoaded = true;
        // 显示加载提示
        loading?.classList.add("show");
        // 更新视频源
        video.src = src;
        video.load();
        // 自动播放新视频
        video.play().catch(() => {
          // 自动播放被阻止时，等待用户点击
          loading?.classList.remove("show");
        });

        // 更新选集列表高亮状态
        playlistItems.forEach((el) => {
          el.classList.remove("active");
        });
        activeItem.classList.add("active");
      }

      // 选集列表项点击切换
      playlistItems.forEach((item) => {
        item.addEventListener("click", () => {
          const src = item.dataset.videoSrc || "";
          switchPlaylistVideo(src, item);
        });
      });

      /**
       * 延迟加载逻辑
       * 视频源加载状态标记，防止重复加载
       * 仅在用户点击播放按钮或选集时才加载视频，避免页面加载时并发请求多个大文件
       */
      let videoLoaded = false;

      /**
       * 加载第一个选集视频（延迟触发）
       * 用户点击播放按钮时调用，加载后自动播放
       */
      function loadFirstVideo() {
        if (videoLoaded) return;
        videoLoaded = true;
        if (playlistItems.length > 0) {
          const firstItem = playlistItems[0];
          const src = firstItem.dataset.videoSrc || "";
          if (src) {
            video.src = src;
            video.load();
            // 加载后自动播放
            video.play().catch(() => {
              // 自动播放被阻止时，等待用户再次点击
            });
          }
        }
      }

      // 初始更新图标状态
      updatePlayIcon();
      updateMuteIcon();
    });
  });
</script>
