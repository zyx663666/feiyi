---
/**
 * 视频动画页（整合页）
 * 使用本地视频素材，三大手艺专题展示
 * 功能：
 *   1. 顶部轮播图：自动循环播放5个视频的切片片段（每个播放约15秒）
 *   2. 三大专题区：自定义HTML5播放器 + B站风格视频选集列表
 *   3. 背景图区域水波纹涟漪交互
 * 视频素材存放于 public/videos/ 目录
 */
import Layout from "../components/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;

/**
 * 全部本地视频素材清单
 * 每个视频包含：唯一ID、标题、副标题、视频源路径、所属非遗类别
 * 视频文件存放于 public/videos/，文件名使用英文便于引用
 */
const allVideos = [
  {
    id: "ceramic-zhiciyisheng",
    title: "只瓷一生",
    subtitle: "景德镇手工制瓷技艺纪录片",
    src: `${base}videos/ceramic-zhiciyisheng.mp4`,
    category: "ceramic",
    categoryLabel: "陶瓷",
  },
  {
    id: "embroidery-guangxiu",
    title: "多彩广绣",
    subtitle: "人民日报×梁晓曼",
    src: `${base}videos/embroidery-guangxiu.mp4`,
    category: "embroidery",
    categoryLabel: "刺绣",
  },
  {
    id: "embroidery-suxiu",
    title: "苏绣",
    subtitle: "中国四大名绣之一",
    src: `${base}videos/embroidery-suxiu.mp4`,
    category: "embroidery",
    categoryLabel: "刺绣",
  },
  {
    id: "woodcarving-jiangxin",
    title: "匠心",
    subtitle: "传统木雕的传承人",
    src: `${base}videos/woodcarving-jiangxin.mp4`,
    category: "woodcarving",
    categoryLabel: "木雕",
  },
  {
    id: "woodcarving-muban-nianhua",
    title: "木版年画",
    subtitle: "国家级非遗微宣传片",
    src: `${base}videos/woodcarving-muban-nianhua.mp4`,
    category: "woodcarving",
    categoryLabel: "木雕",
  },
];

/**
 * 三大非遗手艺专题数据
 * 每个专题包含：背景图、渐变色调、介绍文案、关联视频列表
 * videos 字段为该专题下所有可切换播放的视频数组
 */
const crafts = [
  {
    id: "ceramic",
    name: "陶瓷技艺",
    subtitle: "CERAMIC ART",
    quote: "泥土有性，窑火无情，匠人有心",
    desc: "从一团泥土到精美瓷器，历经拉坯、修坯、上釉、烧制数十道工序。千年窑火不息，承载着东方美学的极致追求。",
    bg: `${base}images/backgrounds/ceramic-bg.png`,
    // 陶瓷专题渐变：青花蓝调
    gradient: "linear-gradient(135deg, rgba(30,50,80,0.85) 0%, rgba(20,35,60,0.7) 100%)",
    accentColor: "#4a90d9",
    // 陶瓷专题仅1个视频
    videos: [allVideos[0]],
  },
  {
    id: "embroidery",
    name: "刺绣工艺",
    subtitle: "EMBROIDERY",
    quote: "一针一线，绣出锦绣乾坤",
    desc: "苏绣的细腻、蜀绣的明丽、湘绣的写实、粤绣的华贵，四大名绣各具风韵。丝线在指尖流转，化作花鸟鱼虫、山川人物。",
    bg: `${base}images/backgrounds/embroidery-bg.png`,
    // 刺绣专题渐变：丝线红粉调
    gradient: "linear-gradient(135deg, rgba(120,40,60,0.85) 0%, rgba(80,25,45,0.7) 100%)",
    accentColor: "#d94a6a",
    // 刺绣专题包含广绣、苏绣2个视频，可在播放器中切换
    videos: [allVideos[1], allVideos[2]],
  },
  {
    id: "woodcarving",
    name: "木雕技艺",
    subtitle: "WOODCARVING",
    quote: "刀尖上的艺术，化木为神奇",
    desc: "东阳木雕的精雕细琢、徽派木雕的古朴大气、黄杨木雕的圆润温润。一刀一凿之间，赋予木材以生命与灵魂。",
    bg: `${base}images/backgrounds/woodcarving-bg.png`,
    // 木雕专题渐变：琥珀木纹调
    gradient: "linear-gradient(135deg, rgba(100,70,30,0.85) 0%, rgba(60,40,15,0.7) 100%)",
    accentColor: "#d9a44a",
    // 木雕专题包含木雕匠心、木版年画2个视频，可在播放器中切换
    videos: [allVideos[3], allVideos[4]],
  },
];

/**
 * 轮播图配置
 * CLIP_DURATION: 每个视频切片的播放时长（秒），到时自动切换到下一个视频
 */
const CAROUSEL_CLIP_DURATION = 15;
---

<Layout title="视频动画 - 非遗传承">
  <Navigation />

  <main class="animation-main">
    <!-- ============================================
         Hero 区域
         ============================================ -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="hero-subtitle reveal" data-delay="0">ANIMATION</p>
        <h1 class="hero-title reveal" data-delay="200">光影非遗</h1>
        <p class="hero-desc reveal" data-delay="400">用影像讲述千年技艺的故事</p>
        <div class="hero-line reveal" data-delay="600"></div>
      </div>
      <div class="hero-scroll reveal" data-delay="800">
        <span>向下探索</span>
        <div class="scroll-arrow"></div>
      </div>
    </section>

    <!-- ============================================
         视频轮播图区
         自动循环播放5个视频的切片片段（每个播放约15秒）
         静音自动播放（浏览器策略要求）
         ============================================ -->
    <section class="carousel-section">
      <div class="container">
        <div class="section-header">
          <p class="section-subtitle">SHOWCASE</p>
          <h2 class="section-title">非遗影像</h2>
          <div class="section-line"></div>
        </div>

        <!-- 轮播主体：左侧视频播放区 + 右侧视频列表 -->
        <div class="carousel-wrapper" data-carousel>
          <!-- 左侧：视频播放区 -->
          <div class="carousel-stage">
            <video
              class="carousel-video"
              data-carousel-video
              muted
              playsinline
              preload="metadata"
            ></video>
            <!-- 视频遮罩信息层（标题、序号、进度条） -->
            <div class="carousel-overlay">
              <div class="carousel-info">
                <span class="carousel-category" data-carousel-category></span>
                <h3 class="carousel-title" data-carousel-title></h3>
                <p class="carousel-subtitle" data-carousel-subtitle></p>
              </div>
              <div class="carousel-progress" data-carousel-progress>
                <div class="carousel-progress-bar" data-carousel-progress-bar></div>
              </div>
            </div>
            <!-- 静音/取消静音切换按钮 -->
            <button class="carousel-mute-btn" data-carousel-mute aria-label="切换静音">
              <span class="icon-muted">🔇</span>
              <span class="icon-sound" style="display:none;">🔊</span>
            </button>
          </div>

          <!-- 右侧：视频选集列表（可点击切换） -->
          <div class="carousel-list" data-carousel-list>
            {allVideos.map((video, index) => (
              <button
                class="carousel-item"
                data-carousel-item={index}
                data-video-src={video.src}
                data-video-title={video.title}
                data-video-subtitle={video.subtitle}
                data-video-category={video.categoryLabel}
              >
                <span class="carousel-item-index">{String(index + 1).padStart(2, "0")}</span>
                <div class="carousel-item-info">
                  <span class="carousel-item-tag">{video.categoryLabel}</span>
                  <span class="carousel-item-title">{video.title}</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         三大非遗手艺专题区
         每个专题：背景图 banner（水波纹交互）+ 介绍 + 自定义播放器
         ============================================ -->
    {crafts.map((craft, index) => (
      <section class="craft-section" id={`craft-${craft.id}`} data-craft={craft.id}>
        <!-- 背景图 banner 区（水波纹交互） -->
        <div
          class="craft-banner"
          data-ripple
          style={`background-image: url('${craft.bg}');`}
        >
          <!-- 渐变遮罩层 -->
          <div class="craft-banner-overlay" style={`background: ${craft.gradient};`}></div>
          <!-- 水波纹 canvas 层 -->
          <canvas class="ripple-canvas" aria-hidden="true"></canvas>
          <!-- banner 文字内容 -->
          <div class="craft-banner-content">
            <p class="craft-subtitle">{craft.subtitle}</p>
            <h2 class="craft-name">{craft.name}</h2>
            <p class="craft-quote">「 {craft.quote} 」</p>
          </div>
          <!-- 序号标记 -->
          <span class="craft-index">0{index + 1}</span>
        </div>

        <!-- 手艺介绍 + 自定义播放器区 -->
        <div class="craft-body">
          <div class="container">
            <div class="craft-layout">
              <!-- 介绍文字 -->
              <div class="craft-intro">
                <div class="craft-intro-line" style={`background: ${craft.accentColor};`}></div>
                <h3 class="craft-intro-title">工艺简介</h3>
                <p class="craft-intro-text">{craft.desc}</p>
                <a href={`${base}crafts/${craft.id}`} class="craft-link" style={`--accent: ${craft.accentColor};`}>
                  了解更多 →
                </a>
              </div>

              <!-- 自定义视频播放器 + B站风格选集列表 -->
              <div class="craft-player-zone">
                {/* 播放器容器：data-craft-player 关联专题ID，用于JS初始化 */}
                <div class="custom-player" data-craft-player={craft.id} data-accent={craft.accentColor}>
                  {/* 视频画面区 */}
                  <div class="player-stage">
                    <video
                      class="player-video"
                      data-player-video
                      preload="metadata"
                      playsinline
                    ></video>

                    {/* 播放器中央大播放按钮（暂停态显示） */}
                    <button class="player-big-play" data-player-big-play aria-label="播放">
                      <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </button>

                    {/* 加载提示 */}
                    <div class="player-loading" data-player-loading>加载中…</div>

                    {/* 自定义控制条 */}
                    <div class="player-controls" data-player-controls>
                      {/* 进度条区域 */}
                      <div class="player-progress" data-player-progress>
                        <div class="player-progress-buffer" data-player-buffer></div>
                        <div class="player-progress-filled" data-player-filled></div>
                        <div class="player-progress-thumb" data-player-thumb></div>
                      </div>

                      {/* 控制按钮组 */}
                      <div class="player-buttons">
                        {/* 播放/暂停 */}
                        <button class="player-btn" data-player-play aria-label="播放/暂停">
                          <svg class="icon-play" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <path d="M8 5v14l11-7z" />
                          </svg>
                          <svg class="icon-pause" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="display:none;">
                            <path d="M6 5h4v14H6zm8 0h4v14h-4z" />
                          </svg>
                        </button>

                        {/* 时间显示 */}
                        <span class="player-time" data-player-time>00:00 / 00:00</span>

                        {/* 音量控制 */}
                        <div class="player-volume">
                          <button class="player-btn" data-player-mute aria-label="静音切换">
                            <svg class="icon-sound" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.06A4.5 4.5 0 0016.5 12zM14 3.23v2.06A7 7 0 0119 12a7 7 0 01-5 6.71v2.06A9 9 0 0021 12a9 9 0 00-7-8.77z" />
                            </svg>
                            <svg class="icon-muted" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="display:none;">
                              <path d="M16.5 12A4.5 4.5 0 0014 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51A8.8 8.8 0 0021 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06a8.99 8.99 0 003.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z" />
                            </svg>
                          </button>
                          <input
                            type="range"
                            class="player-volume-slider"
                            data-player-volume
                            min="0"
                            max="1"
                            step="0.05"
                            value="1"
                            aria-label="音量"
                          />
                        </div>

                        {/* 全屏按钮 */}
                        <button class="player-btn player-btn-right" data-player-fullscreen aria-label="全屏">
                          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                            <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z" />
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>

                  {/* B站风格视频选集列表 */}
                  <div class="player-playlist" data-player-playlist>
                    <div class="playlist-header">
                      <span class="playlist-title">选集（{craft.videos.length}）</span>
                      <span class="playlist-hint">点击切换</span>
                    </div>
                    <div class="playlist-items">
                      {craft.videos.map((video, vIndex) => (
                        <button
                          class:list={["playlist-item", { active: vIndex === 0 }]}
                          data-playlist-item={vIndex}
                          data-video-src={video.src}
                          data-video-title={video.title}
                          data-video-subtitle={video.subtitle}
                        >
                          <span class="playlist-item-index">P{vIndex + 1}</span>
                          <div class="playlist-item-info">
                            <span class="playlist-item-title">{video.title}</span>
                            <span class="playlist-item-sub">{video.subtitle}</span>
                          </div>
                          <span class="playlist-item-playing">▶ 播放中</span>
                        </button>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- 底部引导 -->
    <section class="bottom-cta">
      <div class="container">
        <p class="cta-text">想亲身体验非遗技艺？</p>
        <a href={`${base}game`} class="cta-btn">前往互动游戏 →</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ============================================
   * 主容器
   * ============================================ */
  .animation-main {
    padding-top: var(--nav-height);
    background: var(--color-bg-dark);
    position: relative;
    z-index: 1;
  }

  /* ============================================
   * Hero 区域
   * ============================================ */
  .hero {
    position: relative;
    height: 75vh;
    min-height: 520px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    /* Hero 渐变背景：深色多段渐变 */
    background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 30%, #2d1f3a 70%, #1a1a2e 100%);
    z-index: 1;
  }

  .hero-bg::before {
    content: "";
    position: absolute;
    top: 20%;
    left: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(196, 163, 90, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    animation: floatGlow 8s ease-in-out infinite;
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    bottom: 10%;
    right: 15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(178, 34, 34, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    animation: floatGlow 10s ease-in-out infinite reverse;
  }

  @keyframes floatGlow {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    50% { transform: translate(40px, -30px) scale(1.1); opacity: 1; }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(15, 15, 26, 0.4) 100%);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    color: var(--color-text-light);
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.5em;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-lg);
    opacity: 0.8;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 400;
    color: var(--color-text-light);
    /* 标题渐变文字 */
    background: linear-gradient(135deg, #f5f0e8 0%, #c4a35a 50%, #f5f0e8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 4px 30px rgba(196, 163, 90, 0.3);
    margin-bottom: var(--spacing-md);
    letter-spacing: 0.1em;
  }

  .hero-desc {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: rgba(245, 240, 232, 0.8);
    margin-bottom: var(--spacing-lg);
    letter-spacing: 0.2em;
  }

  .hero-line {
    width: 60px;
    height: 2px;
    margin: 0 auto;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
    animation: lineExpand 2s ease-in-out infinite;
  }

  @keyframes lineExpand {
    0%, 100% { width: 60px; opacity: 0.6; }
    50% { width: 120px; opacity: 1; }
  }

  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    color: rgba(245, 240, 232, 0.6);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-align: center;
  }

  .scroll-arrow {
    width: 1px;
    height: 40px;
    margin: 12px auto 0;
    background: linear-gradient(to bottom, var(--color-secondary), transparent);
    position: relative;
    animation: scrollDown 2s ease-in-out infinite;
  }

  .scroll-arrow::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 8px;
    height: 8px;
    border-right: 1px solid var(--color-secondary);
    border-bottom: 1px solid var(--color-secondary);
  }

  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ============================================
   * 通用区块标题
   * ============================================ */
  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.5em;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-sm);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
    letter-spacing: 0.1em;
  }

  .section-line {
    width: 60px;
    height: 2px;
    margin: 0 auto;
    background: linear-gradient(90deg, transparent, var(--color-secondary), transparent);
  }

  /* ============================================
   * 视频轮播图区
   * ============================================ */
  .carousel-section {
    padding: var(--spacing-2xl) 0;
    background: var(--color-bg-dark);
  }

  .carousel-wrapper {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--spacing-lg);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* 左侧视频播放区 */
  .carousel-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: #000;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(196, 163, 90, 0.2);
  }

  .carousel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* 视频遮罩信息层 */
  .carousel-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--spacing-lg);
    background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.8) 100%);
