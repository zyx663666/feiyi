---
/**
 * 视频动画页（占位）
 * 后续实现非遗技艺科普视频播放
 */
import Layout from "../components/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="视频动画">
  <Navigation />
  <main class="placeholder-main">
    <div class="container">
      <h1 class="placeholder-title">视频动画</h1>
      <p class="placeholder-desc">这里将展示非遗技艺溯源、制作流程与传承人故事视频。</p>
      <a href={import.meta.env.BASE_URL} class="placeholder-back">← 返回首页</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .placeholder-main {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: var(--nav-height);
    text-align: center;
  }

  .placeholder-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .placeholder-desc {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .placeholder-back {
    color: var(--color-accent);
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .placeholder-back:hover {
    color: var(--color-primary);
  }
</style>
