---
/**
 * 点阵背景效果还原页（dotgrid-demo.astro）
 * 完整还原 updream.cn 登录后网页的背景效果
 * 技术参考：react-bits DotGrid 组件
 *   - 深紫底色 #0D0B1F
 *   - 规则点阵网格（密集）
 *   - 鼠标范围内点变大变亮（baseColor → activeColor 颜色过渡）
 *   - 鼠标移开后逐渐还原（非瞬间）
 *   - 随机微波浪（部分点缓慢起伏，不明显）
 *   - 点击触发扩散冲击波
 *   - 粒子随页面滚动同步移动（粒子像固定在页面上）
 * 访问路径：/dotgrid-demo
 */
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>点阵背景还原 - DotGrid Demo</title>
  <style>
    /* 全局重置 */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      width: 100%;
      background-color: #0D0B1F;
      font-family: "Noto Sans SC", "Microsoft YaHei", sans-serif;
      cursor: crosshair;
      /* 允许滚动以展示粒子滚动同步效果 */
    }

    /* 点阵背景 canvas：fixed 铺满视口，绘制时考虑滚动偏移实现同步 */
    #dot-grid-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      display: block;
      z-index: 0;
      pointer-events: none;
    }

    /* 可滚动占位内容区：让页面可滚动以展示粒子滚动同步 */
    .scroll-content {
      position: relative;
      z-index: 1;
      pointer-events: none;
    }

    .scroll-section {
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.7);
      text-align: center;
      padding: 0 24px;
    }

    .scroll-section h2 {
      font-size: 2rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      margin-bottom: 16px;
      color: rgba(255, 255, 255, 0.85);
    }

    .scroll-section p {
      font-size: 0.95rem;
      letter-spacing: 0.1em;
      line-height: 2;
      color: rgba(255, 255, 255, 0.5);
      max-width: 480px;
    }

    /* 顶部提示 */
    .hint {
      position: fixed;
      top: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.875rem;
      letter-spacing: 0.1em;
      pointer-events: none;
      user-select: none;
      text-align: center;
      line-height: 1.8;
    }

    .hint .title {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 6px;
      letter-spacing: 0.2em;
    }

    /* 返回链接 */
    .back-link {
      position: fixed;
      bottom: 24px;
      left: 24px;
      z-index: 10;
      color: rgba(255, 255, 255, 0.4);
      font-size: 0.8rem;
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.3s ease;
      pointer-events: auto;
    }

    .back-link:hover {
      color: #5227FF;
    }
  </style>
</head>
<body>
  <!-- 点阵背景画布（fixed，绘制时同步滚动偏移） -->
  <canvas id="dot-grid-canvas"></canvas>

  <!-- 可滚动占位内容：展示粒子随滚动同步 -->
  <div class="scroll-content">
    <section class="scroll-section">
      <h2>DotGrid 点阵还原</h2>
      <p>移动鼠标查看光斑效果 · 点击触发扩散冲击波<br>向下滚动观察粒子随页面同步移动</p>
    </section>
    <section class="scroll-section">
      <h2>滚动同步</h2>
      <p>粒子背景随页面滚动而移动<br>粒子位置与页面内容保持同步</p>
    </section>
    <section class="scroll-section">
      <h2>随机波浪</h2>
      <p>点阵自带缓慢的随机起伏波浪<br>细微不易察觉，赋予背景生命力</p>
    </section>
    <section class="scroll-section">
      <h2>逐渐还原</h2>
      <p>鼠标移开后点会缓慢回归基础状态<br>而非瞬间复原</p>
    </section>
  </div>

  <!-- 顶部提示 -->
  <div class="hint">
    <div class="title">DotGrid 点阵背景还原</div>
    <div>移动鼠标 · 点击扩散 · 滚动页面观察同步</div>
  </div>

  <!-- 返回首页 -->
  <a href="/" class="back-link">← 返回首页</a>

  <script>
    /**
     * DotGrid 点阵背景管理器（增强版）
     * 功能：
     *   1. 规则点阵网格生成（密集）
     *   2. 鼠标移动时感应半径内点变大变亮（颜色 baseColor → activeColor 过渡）
     *   3. 鼠标移开后逐渐还原（缓慢缓动，非瞬间）
     *   4. 随机微波浪：基于正弦波 + 位置，部分点缓慢起伏（不明显）
     *   5. 点击触发径向扩散冲击波
     *   6. 粒子随页面滚动同步（绘制 y 偏移 = -(scrollY % gap)，无缝平铺）
     */
    class DotGrid {
      private canvas: HTMLCanvasElement;
      private ctx: CanvasRenderingContext2D;
      private dots: Dot[] = [];
      private mouse = { x: -9999, y: -9999 };
      private ripples: Ripple[] = [];
      private rafId = 0;
      private dpr = 1;
      private scrollY = 0;
      private time = 0;

      // 视觉参数
      private dotSize = 1.6;          // 基础点半径（更小更密集）
      private activeDotSize = 5;      // 激活点半径
      private gap = 22;               // 点阵间距（更密集）
      private proximity = 150;        // 鼠标感应半径
      private shockStrength = 6;      // 点击冲击强度
      private returnEase = 0.022;     // 回归缓动系数（很小 → 缓慢还原，保持更久）
      private waveAmplitude = 0.18;   // 随机波浪幅度（增强，肉眼可见但不喧宾夺主）

      // 颜色（updream.cn 紫色系）
      private baseColor = { r: 61, g: 43, b: 92 };    // #3D2B5C 暗紫
      private activeColor = { r: 82, g: 39, b: 255 };  // #5227FF 亮紫
      private bgColor = { r: 13, g: 11, b: 31 };       // #0D0B1F 深紫黑

      constructor(canvas: HTMLCanvasElement) {
        this.canvas = canvas;
        this.ctx = canvas.getContext("2d")!;
        this.dpr = window.devicePixelRatio || 1;
        this.resize();
        this.bindEvents();
        this.animate();
      }

      /** 设置 canvas 尺寸（适配高分屏）并生成点阵 */
      private resize(): void {
        const w = window.innerWidth;
        const h = window.innerHeight;
        this.canvas.width = w * this.dpr;
        this.canvas.height = h * this.dpr;
        this.canvas.style.width = w + "px";
        this.canvas.style.height = h + "px";
        this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
        this.createDots();
      }

      /**
       * 生成规则点阵网格
       * 生成视口范围 + 边距的网格，配合滚动偏移实现无缝平铺
       */
      private createDots(): void {
        this.dots = [];
        const w = window.innerWidth;
        const h = window.innerHeight;
        const cols = Math.ceil(w / this.gap) + 2;
        const rows = Math.ceil(h / this.gap) + 2;
        const offsetX = (w - (cols - 1) * this.gap) / 2;
        const offsetY = (h - (rows - 1) * this.gap) / 2;

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            this.dots.push({
              baseX: offsetX + col * this.gap,
              baseY: offsetY + row * this.gap,
              size: this.dotSize,
              targetSize: this.dotSize,
              intensity: 0,
              targetIntensity: 0,
              // 波浪相位：每个点固定一个相位偏移，让波浪流动
              wavePhase: Math.random() * Math.PI * 2,
            });
          }
        }
      }

      /** 绑定事件 */
      private bindEvents(): void {
        // 鼠标移动
        window.addEventListener("mousemove", (e) => {
          this.mouse.x = e.clientX;
          this.mouse.y = e.clientY;
        });

        // 鼠标离开视口
        window.addEventListener("mouseleave", () => {
          this.mouse.x = -9999;
          this.mouse.y = -9999;
        });

        // 点击：产生扩散冲击波（使用视口坐标，固定在点击位置扩散）
        window.addEventListener("click", (e) => {
          this.ripples.push({
            viewX: e.clientX,
            viewY: e.clientY,
            radius: 0,
            maxRadius: Math.max(window.innerWidth, window.innerHeight) * 0.7,
            strength: this.shockStrength,
            life: 1,
          });
        });

        // 滚动：记录滚动偏移（粒子随页面同步移动）
        window.addEventListener("scroll", () => {
          this.scrollY = window.scrollY;
        }, { passive: true });

        // 窗口尺寸变化
        window.addEventListener("resize", () => {
          this.dpr = window.devicePixelRatio || 1;
          this.resize();
        });
      }

      /** 计算鼠标对单点的影响强度（0~1），基于点的实际绘制位置（视口坐标） */
      private getMouseInfluence(dot: Dot): number {
        // 点的实际绘制 y（考虑滚动偏移）
        const drawY = dot.baseY - (this.scrollY % this.gap);
        const dx = this.mouse.x - dot.baseX;
        const dy = this.mouse.y - drawY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist >= this.proximity) return 0;
        const t = dist / this.proximity;
        return 1 - t * t;
      }

      /** 计算冲击波对单点的影响强度，基于点的实际绘制位置（视口坐标） */
      private getRippleInfluence(dot: Dot): { intensity: number } {
        let intensity = 0;
        const drawY = dot.baseY - (this.scrollY % this.gap);

        for (const ripple of this.ripples) {
          const dx = dot.baseX - ripple.viewX;
          const dy = drawY - ripple.viewY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const bandWidth = 80;
          const diff = Math.abs(dist - ripple.radius);
          if (diff < bandWidth) {
            const bandStrength = 1 - diff / bandWidth;
            intensity = Math.max(intensity, bandStrength * ripple.life);
          }
        }
        return { intensity };
      }

      /** 计算随机波浪强度（基于正弦波 + 时间 + 位置，不明显） */
      private getWaveIntensity(dot: Dot): number {
        // 多频率正弦叠加，形成缓慢流动的波浪
        const wave =
          Math.sin(this.time * 0.0008 + dot.baseX * 0.012 + dot.wavePhase) * 0.5 +
          Math.sin(this.time * 0.0005 + dot.baseY * 0.01 + dot.wavePhase * 1.3) * 0.5;
        // wave 范围 -1~1，映射到 0~1
        const normalized = (wave + 1) / 2;
        return normalized * this.waveAmplitude;
      }

      /** 更新所有点状态 */
      private update(deltaTime: number): void {
        this.time += deltaTime;

        // 更新冲击波
        this.ripples = this.ripples.filter((r) => {
          r.radius += 8;
          r.life -= 0.012;
          return r.life > 0 && r.radius < r.maxRadius;
        });

        for (const dot of this.dots) {
          // 鼠标影响
          const mouseInfluence = this.getMouseInfluence(dot);
          // 冲击波影响
          const ripple = this.getRippleInfluence(dot);
          // 随机波浪影响（细微）
          const wave = this.getWaveIntensity(dot);

          // 目标尺寸
          dot.targetSize = this.dotSize
            + (this.activeDotSize - this.dotSize) * mouseInfluence
            + ripple.intensity * 3;

          // 目标激活强度：鼠标 + 冲击波 + 波浪
          dot.targetIntensity = Math.min(1, mouseInfluence + ripple.intensity * 0.6 + wave);

          // 平滑过渡（逐渐还原，非瞬间）
          dot.size += (dot.targetSize - dot.size) * this.returnEase;
          dot.intensity += (dot.targetIntensity - dot.intensity) * this.returnEase;
        }
      }

      /** 颜色线性插值 */
      private lerpColor(t: number): string {
        const r = Math.round(this.baseColor.r + (this.activeColor.r - this.baseColor.r) * t);
        const g = Math.round(this.baseColor.g + (this.activeColor.g - this.baseColor.g) * t);
        const b = Math.round(this.baseColor.b + (this.activeColor.b - this.baseColor.b) * t);
        return `rgb(${r}, ${g}, ${b})`;
      }

      /** rgb 字符串转 rgba */
      private rgbToRgba(rgb: string, alpha: number): string {
        const match = rgb.match(/\d+/g);
        if (!match) return rgb;
        const [r, g, b] = match;
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
      }

      /** 绘制一帧 */
      private draw(): void {
        const w = window.innerWidth;
        const h = window.innerHeight;

        // 清屏（背景色填充）
        this.ctx.fillStyle = `rgb(${this.bgColor.r}, ${this.bgColor.g}, ${this.bgColor.b})`;
        this.ctx.fillRect(0, 0, w, h);

        // 滚动偏移：粒子随页面上移（scrollY 增大 → y 减小），用 modulo 实现无缝平铺
        const scrollOffsetY = -(this.scrollY % this.gap);

        // 绘制所有点
        for (const dot of this.dots) {
          if (dot.size <= 0.1) continue;

          // 实际绘制 y = 基础 y + 滚动偏移
          const drawY = dot.baseY + scrollOffsetY;

          // 激活点添加光晕
          if (dot.intensity > 0.1) {
            const glowRadius = dot.size * 4;
            const glow = this.ctx.createRadialGradient(
              dot.baseX, drawY, 0,
              dot.baseX, drawY, glowRadius
            );
            const glowColor = this.lerpColor(dot.intensity);
            glow.addColorStop(0, this.rgbToRgba(glowColor, dot.intensity * 0.4));
            glow.addColorStop(1, this.rgbToRgba(glowColor, 0));
            this.ctx.beginPath();
            this.ctx.arc(dot.baseX, drawY, glowRadius, 0, Math.PI * 2);
            this.ctx.fillStyle = glow;
            this.ctx.fill();
          }

          // 点核心
          this.ctx.beginPath();
          this.ctx.arc(dot.baseX, drawY, Math.max(0.5, dot.size), 0, Math.PI * 2);
          this.ctx.fillStyle = this.lerpColor(dot.intensity);
          this.ctx.fill();
        }

        // 绘制冲击波环（视口坐标，固定在点击位置扩散）
        for (const ripple of this.ripples) {
          this.ctx.beginPath();
          this.ctx.arc(ripple.viewX, ripple.viewY, ripple.radius, 0, Math.PI * 2);
          this.ctx.strokeStyle = this.rgbToRgba(
            this.lerpColor(ripple.life),
            ripple.life * 0.15
          );
          this.ctx.lineWidth = 2;
          this.ctx.stroke();
        }
      }

      /** 动画循环 */
      private lastTime = 0;
      private animate = (timestamp: number = 0): void => {
        const deltaTime = timestamp - this.lastTime;
        this.lastTime = timestamp;
        this.update(deltaTime);
        this.draw();
        this.rafId = requestAnimationFrame(this.animate);
      };

      /** 销毁 */
      public destroy(): void {
        cancelAnimationFrame(this.rafId);
      }
    }

    /** 点数据结构 */
    interface Dot {
      baseX: number;
      baseY: number;
      size: number;
      targetSize: number;
      intensity: number;
      targetIntensity: number;
      wavePhase: number;
    }

    /** 冲击波数据结构（使用视口坐标，固定在点击位置扩散） */
    interface Ripple {
      viewX: number;
      viewY: number;
      radius: number;
      maxRadius: number;
      strength: number;
      life: number;
    }

    // module 脚本默认 defer，DOM 已就绪，直接初始化
    const canvas = document.getElementById("dot-grid-canvas") as HTMLCanvasElement | null;
    if (canvas) {
      const grid = new DotGrid(canvas);
      window.addEventListener("beforeunload", () => grid.destroy());
    }
  </script>
</body>
</html>
